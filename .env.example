# Django
SECRET_KEY=change-me-to-something-random
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- LLM (free API) ---
# Default is set up for Groq (https://console.groq.com) which has a generous free tier
# and an OpenAI-compatible /chat/completions endpoint. You can swap this for any
# OpenAI-compatible provider (OpenRouter, Together, local Ollama, etc) by changing
# LLM_API_BASE + LLM_MODEL.
LLM_API_BASE=https://api.groq.com/openai/v1
LLM_API_KEY=your-groq-api-key-here
LLM_MODEL=llama-3.3-70b-versatile
